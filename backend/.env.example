DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
JWT_SECRET=use-a-long-random-string
CORS_ORIGIN=*

# First admin: comma-separated emails get role=admin on register
ADMIN_EMAILS=owner@yourboutique.com

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

CLOUDINARY_CLOUD_NAME=your_cloud

# Optional FCM HTTP v1 (short-lived token from service account)
FCM_PROJECT_ID=
FCM_ACCESS_TOKEN=

# Protect cron route (recommended)
CRON_SECRET=random-cron-secret
