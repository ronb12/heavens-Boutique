DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
JWT_SECRET=use-a-long-random-string
CORS_ORIGIN=*

# Admin: comma-separated emails — role=admin on register, and promoted on login if still customer
ADMIN_EMAILS=heavenbowie0913@gmail.com
# After orders decrement stock, admins get one aggregated “low stock” alert per event when any line is at or below this count (default 5).
# ADMIN_LOW_STOCK_THRESHOLD=5

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Product images (admin POST /api/admin/upload) ──
# Production on Vercel: use Blob (no Cloudinary needed).
# 1) Vercel Dashboard → your project → Storage → Create Database → Blob
# 2) Link the Blob store to this project; Vercel adds BLOB_READ_WRITE_TOKEN (or paste the store’s read/write token into Env).
# 3) Redeploy. The API uses Blob whenever this variable is set.
BLOB_READ_WRITE_TOKEN=
# Optional. Omit for default (try public upload, then private if Vercel says the store is private).
# For catalog images in the iOS app, use a **public** Blob store and either omit this or set:
# BLOB_STORE_ACCESS=public
# BLOB_STORE_ACCESS=private
#
# Optional fallback when BLOB_READ_WRITE_TOKEN is unset (e.g. local dev): Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=heavens-boutique/products

# FCM HTTP v1 (server-side push). Project ID must match iOS GoogleService-Info.plist (e.g. taskpilot-ronb12).
FCM_PROJECT_ID=taskpilot-ronb12
# Preferred: one-line JSON for a GCP service account that can call FCM (e.g. firebase-adminsdk@…). Vercel stores this encrypted.
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional fallback: static OAuth2 bearer (expires ~1h; not ideal for production)
# FCM_ACCESS_TOKEN=

# Profit guard on products (POST/PATCH): unit cost vs lowest price after estimated card fees
# Defaults match common US online card pricing (~2.9% + $0.30 per charge). Set to 0 to turn off a component.
# PROFIT_GUARD_CARD_PERCENT=0.029
# PROFIT_GUARD_CARD_FIXED_CENTS=30

# Protect cron route (recommended)
CRON_SECRET=random-cron-secret
